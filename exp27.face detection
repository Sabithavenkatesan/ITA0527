import cv2
img=cv2.imread(r"C:/Users/SABIT/OneDrive/Documents/face.jpg")
img=cv2.resize(img,(300,300))
gray=cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)
faces=cv2.CascadeClassifier(cv2.data.haarcascades+"haarcascade_frontalface_default.xml").detectMultiScale(gray,1.1,4)
for x,y,w,h in faces: cv2.rectangle(img,(x,y),(x+w,y+h),(0,255,0),2)
cv2.imshow("Original + Face Detection", img)
cv2.waitKey(0)
cv2.destroyAllWindows()
