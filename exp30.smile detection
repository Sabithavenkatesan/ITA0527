import cv2
img=cv2.imread(r"C:/Users/SABIT/OneDrive/Documents/face.jpg")
img=cv2.resize(img,(300,300))
gray=cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)
smiles=cv2.CascadeClassifier(cv2.data.haarcascades+"haarcascade_smile.xml").detectMultiScale(gray,1.8,20)
for x,y,w,h in smiles: cv2.rectangle(img,(x,y),(x+w,y+h),(0,255,255),2)
cv2.imshow("Original + Smile", img)
cv2.waitKey(0)
cv2.destroyAllWindows()
