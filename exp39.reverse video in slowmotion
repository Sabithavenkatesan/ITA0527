import cv2
cap = cv2.VideoCapture("video.mp4")
frames = []
while True:
    ret,frame = cap.read()
    if not ret:
        break
    frames.append(frame)
for f in reversed(frames):
    cv2.imshow("Reverse Video",cv2.resize(f,(400,300)))
    if cv2.waitKey(100)==27:
        break
cap.release()
cv2.destroyAllWindows()
